generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BookCategory {
  MEMOIR
  BUSINESS
  YEARBOOK
  OTHER
}

model AppUser {
  id              String   @id @default(uuid())
  authUserId      String   @unique 
  email           String   @unique
  name            String?
  profileImage    String?
  credits         Int      @default(10) 
  
  hasUsedAiRewrite       Boolean  @default(false)
  isSubscribed           Boolean  @default(false)
  stripeCustomerId       String?  @unique
  stripeSubscriptionId   String?  @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  books           Book[]
  transactions    Transaction[]
  aiRevampRecords AiRevampRecord[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  user            AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  stripeEventId   String   @unique
  amount          Float
  currency        String
  status          String
  type            String
  
  createdAt       DateTime @default(now())
}

model Book {
  id              String       @id @default(uuid())
  title           String
  description     String?      
  category        BookCategory @default(OTHER)
  coverImage      String?      
  coverColor      String?      
  status          BookStatus   @default(DRAFT)
  isPublic        Boolean      @default(false)
  
  userId          String
  user            AppUser         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  chapters        Chapter[]
  published       PublishedSnapshot?
  
  
  wordCount       Int          @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([title, userId])
  @@unique([id, userId])
  @@index([userId])
}

model Chapter {
  id              String   @id @default(uuid())
  title           String
  description     String?
  order           Int      
  
  bookId          String
  book            Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  
  pages           Page[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([bookId])
  @@unique([bookId, title])
  @@unique([bookId, order]) 
}

model Page {
  id              String   @id @default(uuid())
  content         Json?    
  textContent     String?  
  order           Int      
  
  chapterId       String
  chapter         Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([chapterId])
  @@unique([chapterId, order])
}

model PublishedSnapshot {
  id              String   @id @default(uuid())
  shareId         String   @unique @default(uuid())
  snapshotData    Json     
  
  bookId          String   @unique
  book            Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shareId])
}

model AiRevampRecord {
  id              String   @id @default(uuid())
  originalText    String
  revampedText    String
  tone            String?
  category        String?
  
  userId          String
  user            AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
}

